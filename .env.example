# Database (monolith = tek veritabanı; varsayılan SQLite)
# Yol, prisma/schema.prisma dosyasına göre: ./dev.db = prisma/dev.db
# Next.js ile çalıştırırken sorun olursa mutlak yol deneyin: file:C:/proje/prisma/dev.db
DATABASE_URL="file:./dev.db"

# İsteğe bağlı: PostgreSQL kullanacaksan prisma/schema.prisma içinde provider = "postgresql" yap ve şunu kullan:
# DATABASE_URL="postgresql://user:password@localhost:5432/scale_your_friends"

# App
NODE_ENV=development
PORT=3000
HOSTNAME=localhost

# Admin panel (email + password for login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Optional: OpenAI for AI analysis (leave empty to use mock)
OPENAI_API_KEY=

# Optional: Redis adapter placeholder (future scaling)
# REDIS_URL=
